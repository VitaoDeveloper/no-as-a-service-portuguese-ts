{
  "name": "no-as-service",
  "version": "1.0.0",
  "description": "Uma API leve que retorna desculpas e rejeições aleatórias.",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
